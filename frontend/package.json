{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:landing": "tsc -b && vite build --config vite.config.landing.ts",
    "build:docs": "tsc -b && vite build --config vite.config.docs.ts",
    "cf:landing:create": "npx wrangler pages project create qjudge-landing --production-branch=main",
    "cf:landing:deploy": "npm run build:landing && npx wrangler pages deploy dist-landing --project-name=qjudge-landing --branch=main",
    "cf:landing:deploy:preview": "npm run build:landing && npx wrangler pages deploy dist-landing --project-name=qjudge-landing --branch=preview",
    "cf:docs:create": "npx wrangler pages project create qjudge-docs --production-branch=main",
    "cf:docs:deploy": "npm run build:docs && npx wrangler pages deploy dist-docs --project-name=qjudge-docs --branch=main",
    "cf:docs:deploy:preview": "npm run build:docs && npx wrangler pages deploy dist-docs --project-name=qjudge-docs --branch=preview",
    "check:docs": "node scripts/check-docs-translations.js",
    "check:i18n": "node scripts/check-i18n-sync.js",
    "check:typography": "node scripts/check-typography-tokens.js",
    "sync:i18n": "node scripts/sync-i18n.js",
    "lint": "eslint . --max-warnings=9999",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:api": "vitest run --config vitest.config.api.ts",
    "test:api:watch": "vitest --config vitest.config.api.ts",
    "test:e2e": "playwright test -c playwright.config.e2e.ts",
    "test:e2e:auth": "playwright test -c playwright.config.e2e.ts tests/e2e/auth.e2e.spec.ts",
    "test:e2e:ui": "playwright test -c playwright.config.e2e.ts --ui --ui-host localhost",
    "test:e2e:debug": "playwright test -c playwright.config.e2e.ts --debug",
    "test:e2e:headed": "playwright test -c playwright.config.e2e.ts --headed",
    "test:e2e:report": "playwright show-report playwright-report-e2e",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@carbon/charts": "^1.27.0",
    "@carbon/charts-react": "^1.27.0",
    "@carbon/icons-react": "^11.70.0",
    "@carbon/react": "^1.96.0",
    "@hookform/resolvers": "^5.2.2",
    "@lobehub/icons": "^5.4.0",
    "@monaco-editor/react": "^4.7.0",
    "@rc-component/qrcode": "~1.1.1",
    "@tanstack/react-query": "^5.90.12",
    "@tiptap/extension-placeholder": "^3.23.2",
    "@tiptap/pm": "^3.23.2",
    "@tiptap/react": "^3.23.2",
    "@tiptap/starter-kit": "^3.23.2",
    "github-markdown-css": "^5.8.1",
    "github-slugger": "^2.0.0",
    "i18next": "^25.7.2",
    "jsqr": "1.4.0",
    "katex": "^0.16.25",
    "mathlive": "^0.109.2",
    "mermaid": "^11.14.0",
    "motion": "^12.34.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.69.0",
    "react-i18next": "^16.4.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.0.8",
    "react-router-dom": "^7.12.1",
    "recur-tw": "^0.16.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sass": "^1.94.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-docs": "9.1.20",
    "@storybook/react-vite": "9.1.20",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/github-slugger": "^1.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "9.1.20",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "monaco-editor": "^0.55.1",
    "storybook": "9.1.20",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "react-router": "^7.12.1",
    "dompurify": "^3.3.2",
    "immutable": "^5.1.5",
    "lodash-es": "^4.17.23"
  }
}
