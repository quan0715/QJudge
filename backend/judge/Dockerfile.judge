FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN for i in 1 2 3; do apt-get update && break || sleep 10; done \
    && apt-get install -y \
    g++ \
    gcc \
    time \
    python3 \
    openjdk-17-jdk-headless \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /judge

RUN useradd -m -u 1001 judge && \
    chown -R judge:judge /judge

USER judge
