# =============================================================================
# Environment Variables for OJ Platform
# =============================================================================

# -----------------------------------------------------------------------------
# Django Settings
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=q-judge.com,localhost,127.0.0.1,backend

# Development: config.settings.dev
# Production:  config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# Environment type: development / production
# Affects cookie security settings (Secure flag for HttpOnly cookies)
DJANGO_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Local Database (Development primary, Production backup)
DB_NAME=online_judge
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=localhost
DB_PORT=5432

# Cloud Database - Supabase (Development secondary, Production primary)
# 
# Supabase Pooler 模式說明:
#   - Transaction Mode (port 6543): 推薦！支援更多併發連接，每個 transaction 後連接回到池
#   - Session Mode (port 5432): 連接數受限於 pool_size，容易達到 MaxClientsInSessionMode
#
CLOUD_DB_NAME=postgres
CLOUD_DB_USER=postgres.your_project_ref
CLOUD_DB_PASSWORD=your_cloud_db_password
CLOUD_DB_HOST=aws-1-ap-northeast-2.pooler.supabase.com
CLOUD_DB_PORT=6543

# Supabase Transaction Mode 連接設置
# Transaction Mode 必須設為 0，因為連接在每個 transaction 後會回到池
CLOUD_DB_CONN_MAX_AGE=0

# SSL 模式: require (推薦), verify-ca, verify-full, disable
CLOUD_DB_SSLMODE=require

# Production Database Selection
# Set to True to use local DB as primary in production (default: False = use cloud)
USE_LOCAL_DB=False

# Backup Database (Production only - for cloud-to-local backup)
# Set BACKUP_DB_HOST to enable periodic backup from cloud to local
# Leave empty to disable backup feature
BACKUP_DB_HOST=postgres
BACKUP_DB_NAME=online_judge
BACKUP_DB_USER=postgres
BACKUP_DB_PASSWORD=postgres
BACKUP_DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# NYCU OAuth Configuration
NYCU_OAUTH_CLIENT_ID=your_nycu_oauth_client_id
NYCU_OAUTH_CLIENT_SECRET=your_nycu_oauth_client_secret

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
VITE_API_TARGET=http://backend:8000

# Frontend API Base URL for testing (optional)
# VITE_API_BASE_URL=http://localhost:8001

# -----------------------------------------------------------------------------
# AI Service Internal Security
# -----------------------------------------------------------------------------
# Shared secret for ai-service -> backend internal HMAC auth
HMAC_SECRET=replace_with_strong_random_hmac_secret

# Shared token for backend -> ai-service internal auth
AI_SERVICE_INTERNAL_TOKEN=replace_with_strong_random_internal_token

# CORS Settings (comma-separated, for production)
CORS_ALLOWED_ORIGINS=https://q-judge.com
CSRF_TRUSTED_ORIGINS=https://q-judge.com

# -----------------------------------------------------------------------------
# Judge Engine Configuration
# -----------------------------------------------------------------------------
JUDGE_ENGINE_ENABLED=True
JUDGE_MAX_CPU_TIME=10
JUDGE_MAX_MEMORY=256

# Docker Judge Advanced Settings
# DOCKER_HOST: Leave empty to use default Docker socket
# DOCKER_HOST=unix:///var/run/docker.sock
# HOST_PROJECT_ROOT is required for Seccomp profile mapping in Docker-in-Docker setup
HOST_PROJECT_ROOT=/path/to/your/project
DOCKER_IMAGE_JUDGE=oj-judge:latest
DOCKER_JUDGE_PIDS_LIMIT=64
DOCKER_JUDGE_TMPFS_SIZE=100M
DOCKER_JUDGE_TIMEOUT=60
# Leave empty to disable Seccomp, or specify path relative to project root
DOCKER_SECCOMP_PROFILE=

# -----------------------------------------------------------------------------
# Email Configuration (Production)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password

# -----------------------------------------------------------------------------
# Production Database SSL
# -----------------------------------------------------------------------------
# Set to 'disable' when using local Docker postgres (no SSL support)
# Set to 'require' when using cloud DB (e.g. Supabase)
# DB_SSLMODE=disable

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (Production)
# -----------------------------------------------------------------------------
TUNNEL_TOKEN=your_cloudflare_tunnel_token
