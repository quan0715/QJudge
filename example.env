# =============================================================================
# Environment Variables for OJ Platform
# =============================================================================

# -----------------------------------------------------------------------------
# Django Settings
# -----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=q-judge.com,localhost,127.0.0.1,backend

# Development: config.settings.dev
# Production:  config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# Environment type: development / production
# Affects cookie security settings (Secure flag for HttpOnly cookies)
DJANGO_ENV=development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Primary Database
DB_NAME=online_judge
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
# When running WITHOUT Docker Compose, point directly at Postgres.
# When running WITH Docker Compose, DB_HOST/PORT are overridden in the compose
# file to route through pgBouncer (oj_pgbouncer:6432) – do not change here.
DB_HOST=localhost
DB_PORT=5432
# SSL mode for production database connections
# Local docker postgres usually uses "disable"; managed DB usually "require".
DB_SSLMODE=disable
# CONN_MAX_AGE: set to 0 when using pgBouncer (compose default).
# Set to 60-300 only when connecting directly to Postgres without a pooler.
DB_CONN_MAX_AGE=0

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# S3-compatible object storage（MinIO local / Cloudflare R2 production）
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_CORS_ALLOW_ORIGIN=https://q-judge-dev.quan.wtf
# Canonical settings for all S3-compatible features. Use these for new envs.
# Local MinIO example:
OBJECT_STORAGE_ENDPOINT_URL=http://minio:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT_URL=https://minio-dev.quan.wtf
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_PRESIGNED_URL_TTL_SECONDS=300

# Cloudflare R2 production example:
# OBJECT_STORAGE_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# OBJECT_STORAGE_PUBLIC_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_ACCESS_KEY=<r2_access_key_id>
# OBJECT_STORAGE_SECRET_KEY=<r2_secret_access_key>

# -----------------------------------------------------------------------------
# 各功能的 bucket / 大小設定（連線設定共用上面的 OBJECT_STORAGE_*）
# -----------------------------------------------------------------------------
# Anti-cheat
ANTICHEAT_CORS_ALLOWED_ORIGINS=https://q-judge-dev.quan.wtf
ANTICHEAT_RAW_BUCKET=anticheat-raw
ANTICHEAT_VIDEO_BUCKET=anticheat-videos

# Markdown image
MARKDOWN_IMAGE_S3_BUCKET=markdown-images
MARKDOWN_IMAGE_MAX_BYTES=5242880
MARKDOWN_IMAGE_PUBLIC_BASE_URL=https://q-judge-dev.quan.wtf

# AI artifact（exam 批改 SOP 產出物）
AI_ARTIFACT_S3_BUCKET=ai-artifacts
AI_ARTIFACT_MAX_BYTES=10485760

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# NYCU OAuth Configuration
NYCU_OAUTH_CLIENT_ID=your_nycu_oauth_client_id
NYCU_OAUTH_CLIENT_SECRET=your_nycu_oauth_client_secret

# GitHub OAuth Configuration (https://github.com/settings/developers)
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret

# Google OAuth Configuration (https://console.cloud.google.com/apis/credentials)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
VITE_API_TARGET=http://backend:8000

# -----------------------------------------------------------------------------
# AI Service
# -----------------------------------------------------------------------------
# Shared token for backend -> ai-service internal auth
AI_SERVICE_INTERNAL_TOKEN=replace_with_strong_random_internal_token

# DeepSeek API key for LLM inference (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# OpenAI API key for LLM inference (https://platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key

# CORS Settings (comma-separated, for production)
CORS_ALLOWED_ORIGINS=https://q-judge.com
CSRF_TRUSTED_ORIGINS=https://q-judge.com

# -----------------------------------------------------------------------------
# Judge Engine Configuration
# -----------------------------------------------------------------------------
JUDGE_ENGINE_ENABLED=True
JUDGE_MAX_CPU_TIME=10
JUDGE_MAX_MEMORY=256

# Docker Judge Advanced Settings
# DOCKER_HOST: Leave empty to use default Docker socket
# DOCKER_HOST=unix:///var/run/docker.sock
# HOST_PROJECT_ROOT is required for Seccomp profile mapping in Docker-in-Docker setup
HOST_PROJECT_ROOT=/path/to/your/project
DOCKER_IMAGE_JUDGE=oj-judge:latest
DOCKER_JUDGE_PIDS_LIMIT=64
DOCKER_JUDGE_TMPFS_SIZE=100M
DOCKER_JUDGE_TIMEOUT=60
# Leave empty to disable Seccomp, or specify path relative to project root
DOCKER_SECCOMP_PROFILE=

# -----------------------------------------------------------------------------
# Email Configuration (Production)
# -----------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_email_password

# -----------------------------------------------------------------------------
# Cloudflare Tunnel (Production)
# -----------------------------------------------------------------------------
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# -----------------------------------------------------------------------------
# Recur Payment (https://recur.tw)
# -----------------------------------------------------------------------------
RECUR_PUBLISHABLE_KEY=pk_test_your_publishable_key
VITE_RECUR_PUBLISHABLE_KEY=pk_test_your_publishable_key
RECUR_SECRET_KEY=sk_test_your_secret_key
RECUR_WEBHOOK_SECRET=whsec_your_webhook_secret
RECUR_PRODUCT_PRO_ID=your_pro_product_id
RECUR_PRODUCT_TEAM_ID=your_team_product_id
