# QJudge environment template.
# Copy this file to .env and replace every production placeholder before deploy.
# The root .env file is intentionally git-ignored.

# Runtime mode
DJANGO_ENV=development
DJANGO_SETTINGS_MODULE=config.settings.dev
DEBUG=True
SECRET_KEY=change-me-dev-secret-key

# Public URLs and browser security
FRONTEND_URL=http://localhost:5173
OAUTH_ISSUER_URL=http://localhost:8000
MCP_PUBLIC_URL=http://localhost:9002
ALLOWED_HOSTS=localhost,127.0.0.1,backend,q-judge-dev.quan.wtf
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL / PgBouncer
DB_NAME=online_judge
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432
DB_SSLMODE=disable
DB_CONN_MAX_AGE=0

# Redis
REDIS_URL=redis://redis:6379/0

# Local host path used by judge containers through the Docker socket.
# Set this to the absolute repository path when running judge flows locally.
HOST_PROJECT_ROOT=

# OAuth providers
NYCU_OAUTH_CLIENT_ID=
NYCU_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AI service
AI_SERVICE_INTERNAL_TOKEN=dev-ai-internal-token-change-me
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
AI_CREDIT_SCALE_PER_CREDIT=400000

# Judge engine
JUDGE_ENGINE_ENABLED=True
JUDGE_MAX_CPU_TIME=10
JUDGE_MAX_MEMORY=256
DOCKER_IMAGE_JUDGE=oj-judge:latest
DOCKER_JUDGE_PIDS_LIMIT=64
DOCKER_JUDGE_TMPFS_SIZE=100M
DOCKER_JUDGE_TIMEOUT=60

# S3-compatible object storage.
# QJudge uses Cloudflare R2 for dev/staging/production object storage.
OBJECT_STORAGE_ENDPOINT_URL=https://replace-with-account-id.r2.cloudflarestorage.com
OBJECT_STORAGE_PUBLIC_ENDPOINT_URL=https://replace-with-account-id.r2.cloudflarestorage.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY=replace-with-r2-access-key
OBJECT_STORAGE_SECRET_KEY=replace-with-r2-secret-key
OBJECT_STORAGE_PRESIGNED_URL_TTL_SECONDS=300
OBJECT_STORAGE_OBJECT_TAGGING_ENABLED=false
OBJECT_STORAGE_AUTO_CREATE_BUCKETS=false
ANTICHEAT_RAW_BUCKET=anticheat-raw
ANTICHEAT_CAPTURE_INTERVAL_SECONDS=3
MARKDOWN_IMAGE_S3_BUCKET=markdown-images
MARKDOWN_IMAGE_MAX_BYTES=5242880
MARKDOWN_IMAGE_PUBLIC_BASE_URL=http://localhost:5173
AI_ARTIFACT_S3_BUCKET=ai-artifacts
AI_ARTIFACT_MAX_BYTES=10485760

# Loadtest object storage. Use a dedicated bucket to avoid polluting dev/prod evidence.
LOADTEST_OBJECT_STORAGE_ENDPOINT_URL=https://replace-with-account-id.r2.cloudflarestorage.com
LOADTEST_OBJECT_STORAGE_PUBLIC_ENDPOINT_URL=https://replace-with-account-id.r2.cloudflarestorage.com
LOADTEST_OBJECT_STORAGE_REGION=auto
LOADTEST_OBJECT_STORAGE_ACCESS_KEY=replace-with-r2-loadtest-access-key
LOADTEST_OBJECT_STORAGE_SECRET_KEY=replace-with-r2-loadtest-secret-key
LOADTEST_ANTICHEAT_RAW_BUCKET=qjudge-loadtest-anticheat-raw

# Cloudflare Tunnel.
# Dev tunnel is behind the compose "tunnel" profile.
TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# Cloudflare Realtime SFU live monitoring
LIVE_MONITORING_ENABLED=false
LIVE_MONITORING_ROOM_PREFIX=qjudge-dev-exam
CLOUDFLARE_REALTIME_API_BASE_URL=https://rtc.live.cloudflare.com/v1
CLOUDFLARE_REALTIME_APP_ID=
CLOUDFLARE_REALTIME_APP_SECRET=
LIVE_MONITORING_PUBLISHER_TTL_SECONDS=60

# Recur payments
RECUR_PUBLISHABLE_KEY=
VITE_RECUR_PUBLISHABLE_KEY=
RECUR_SECRET_KEY=
RECUR_WEBHOOK_SECRET=
RECUR_PRODUCT_PRO_ID=
RECUR_PRODUCT_TEAM_ID=

# MCP widget overrides
MCP_WIDGET_CLASSROOM_LIST_JS=
MCP_WIDGET_EXAM_PROBLEM_PREVIEW_JS=

# GlitchTip / Sentry-compatible error tracking
GLITCHTIP_DSN=
GLITCHTIP_SECRET_KEY=change-me-glitchtip-secret
GLITCHTIP_FROM_EMAIL=noreply@qjudge.local
GLITCHTIP_DOMAIN=http://localhost:8080
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_ENVIRONMENT=development

# Monitoring overlay
GRAFANA_HOST=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_PASSWORD=admin
GRAFANA_ANON_ENABLED=true

# Email
DEFAULT_FROM_EMAIL=noreply@example.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
