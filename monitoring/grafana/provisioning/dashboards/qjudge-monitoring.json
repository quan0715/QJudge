{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "PostgreSQL Active Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"online_judge\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "title": "PostgreSQL Transactions/s",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"online_judge\"}[1m])",
          "legendFormat": "commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"online_judge\"}[1m])",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "PostgreSQL Cache Hit Ratio",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"online_judge\"} / (pg_stat_database_blks_hit{datname=\"online_judge\"} + pg_stat_database_blks_read{datname=\"online_judge\"})",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      }
    },
    {
      "title": "PostgreSQL Deadlocks",
      "type": "stat",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "targets": [
        {
          "expr": "pg_stat_database_deadlocks{datname=\"online_judge\"}",
          "legendFormat": "deadlocks",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        }
      }
    },
    {
      "title": "Redis Connected Clients",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "clients",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_used_rss_bytes",
          "legendFormat": "rss",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Redis Commands/s",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "cmds/s",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Redis Hit/Miss Ratio",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[1m])",
          "legendFormat": "hits/s",
          "refId": "A"
        },
        {
          "expr": "rate(redis_keyspace_misses_total[1m])",
          "legendFormat": "misses/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "PostgreSQL DB Size & Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"online_judge\"}",
          "legendFormat": "DB size",
          "refId": "A"
        },
        {
          "expr": "pg_stat_database_numbackends{datname=\"online_judge\"}",
          "legendFormat": "backends",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "DB size"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          }
        ]
      }
    },
    {
      "title": "PostgreSQL Tuples/s (insert/update/delete)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"online_judge\"}[1m])",
          "legendFormat": "inserts/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"online_judge\"}[1m])",
          "legendFormat": "updates/s",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"online_judge\"}[1m])",
          "legendFormat": "deletes/s",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Container CPU Usage %",
      "description": "On Linux hosts, container names are shown. On macOS Docker Desktop, cAdvisor may only show container IDs.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"oj_.*\"}[1m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\"/docker/.+\"}[1m])) * 100",
          "legendFormat": "all containers (macOS fallback)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "title": "Container Memory Usage",
      "description": "On Linux hosts, container names are shown. On macOS Docker Desktop, cAdvisor may only show container IDs.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\"oj_.*\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        },
        {
          "expr": "sum(container_memory_usage_bytes{id=~\"/docker/.+\"})",
          "legendFormat": "all containers (macOS fallback)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": [
    "monitoring",
    "qjudge"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "QJudge Monitoring",
  "uid": "qjudge-monitoring",
  "version": 1
}
